{
  "1": {
    "class_type": "CheckpointLoaderSimple",
    "_meta": { "title": "Load FLUX.1 Schnell (fp8 all-in-one)" },
    "inputs": {
      "ckpt_name": "flux1-schnell-fp8.safetensors"
    }
  },
  "2": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Positive prompt" },
    "inputs": {
      "text": __PROMPT__,
      "clip": ["1", 1]
    }
  },
  "3": {
    "class_type": "CLIPTextEncode",
    "_meta": { "title": "Negative (ignored at cfg 1.0)" },
    "inputs": {
      "text": "",
      "clip": ["1", 1]
    }
  },
  "4": {
    "class_type": "EmptySD3LatentImage",
    "_meta": { "title": "Empty FLUX latent (16-channel)" },
    "inputs": {
      "width": __WIDTH__,
      "height": __HEIGHT__,
      "batch_size": 1
    }
  },
  "5": {
    "class_type": "KSampler",
    "_meta": { "title": "FLUX Schnell sampler (4 steps)" },
    "inputs": {
      "seed": __SEED__,
      "steps": 4,
      "cfg": 1.0,
      "sampler_name": "euler",
      "scheduler": "simple",
      "denoise": 1.0,
      "model": ["1", 0],
      "positive": ["2", 0],
      "negative": ["3", 0],
      "latent_image": ["4", 0]
    }
  },
  "6": {
    "class_type": "VAEDecode",
    "_meta": { "title": "Decode latent" },
    "inputs": {
      "samples": ["5", 0],
      "vae": ["1", 2]
    }
  },
  "7": {
    "class_type": "SaveImage",
    "_meta": { "title": "Save portrait" },
    "inputs": {
      "filename_prefix": "flux",
      "images": ["6", 0]
    }
  }
}
